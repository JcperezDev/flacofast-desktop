{
  "name": "flacofast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vue-tsc --noEmit && vite build",
    "check": "pnpm run build && pnpm run server:build",
    "preview": "vite preview --host 127.0.0.1",
    "server:dev": "tsx server/src/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/index.js",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@tauri-apps/api": "^2.10.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "vue": "^3.5.32",
    "vue-router": "^4.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
