# Used by the Coolify backend container
HOST=0.0.0.0
PORT=3000

# Postgres. In docker-compose this points to the postgres service.
POSTGRES_DB=flacofast
POSTGRES_USER=flacofast
POSTGRES_PASSWORD=change_this_postgres_password
DATABASE_URL=postgresql://flacofast:change_this_postgres_password@postgres:5432/flacofast
DATABASE_SSL=false

# Use a long random value. Example: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Your owner/admin account. This user is created/updated on backend startup.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NAME=Owner Admin

# The VPS/WireGuard primary node. This seeds the DB on backend startup.
VPS_HOST=203.0.113.10
WIREGUARD_PORT=51820
SERVER_PUBLIC_KEY=
VPS_NODE_NAME=Main VPS
VPS_REGION=US East
VPS_DNS=1.1.1.1
INTERFACE_NAME=flacofast0
CLIENT_ADDRESS=10.8.0.2/32
ALLOWED_IPS=0.0.0.0/0, ::/0

# Allow the desktop app/dev UI to call the API.
CORS_ORIGIN=tauri://localhost,http://tauri.localhost,http://127.0.0.1:1420

# Used when building/running the desktop frontend, not by the backend itself.
VITE_API_URL=https://api.186.6.82.233.sslip.io
